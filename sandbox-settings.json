{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout -- :*)",
      "Bash(git restore:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git tag -d:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash clear:*)",
      "Bash(git filter-branch:*)",
      "Bash(git reflog expire:*)",
      "Bash(git gc:*)",
      "Bash(git remote add:*)",
      "Bash(git remote set-url:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue close:*)",
      "Bash(gh release:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(sudo:*)",
      "Bash(chmod -R:*)",
      "Bash(chown:*)",

      "Bash(cat /home/dev/.claude/*)",
      "Bash(cat *credentials*)",
      "Bash(cat *.env*)",
      "Bash(cat *.pem*)",
      "Bash(cat /home/dev/.ssh/*)",
      "Bash(grep * /home/dev/.claude/*)",
      "Bash(grep * /home/dev/.ssh/*)",

      "Read(/home/dev/.claude/**)",
      "Read(/home/dev/.ssh/**)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/credentials*.json)",
      "Read(id_rsa*)",
      "Read(id_ed25519*)",

      "Write(/home/dev/.claude/**)",
      "Edit(/home/dev/.claude/**)",
      "Write(/home/dev/.ssh/**)",
      "Edit(/home/dev/.ssh/**)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/*.pem)",
      "Write(**/credentials*.json)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/*.pem)",
      "Edit(**/credentials*.json)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git branch:*)",
      "Bash(cargo install:*)",
      "Bash(npm install -g:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)"
    ],
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git switch -c:*)",
      "Bash(git stash list:*)",
      "Bash(git stash show:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo check:*)",
      "Bash(cargo run:*)",
      "Bash(cargo new:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(which:*)"
    ]
  }
}
